APP_NAME="Sistema de Recaudación"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Guayaquil
APP_URL=http://recaudacion.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=recaudacion
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Payment Gateway Configuration (Pago Medios)
PAYMENT_GATEWAY_URL=https://api.abitmedia.cloud/pagomedios/v2/payment-requests
PAYMENT_GATEWAY_API_KEY=your_api_key_here
PAYMENT_GATEWAY_SECRET_KEY=
PAYMENT_GATEWAY_TIMEOUT=30
PAYMENT_GATEWAY_CALLBACK_URL="${APP_URL}/pago/callback"
PAYMENT_GATEWAY_WEBHOOK_URL="${APP_URL}/webhook/pago"

# Redis (opcional para queues)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@recaudacion.gob.ec"
MAIL_FROM_NAME="${APP_NAME}"
