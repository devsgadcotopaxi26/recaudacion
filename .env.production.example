# Ejemplo de .env para PRODUCCIÓN
# ⚠️ NUNCA commitear este archivo al repositorio

APP_NAME="Sistema de Recaudación"
APP_ENV=production
APP_KEY=base64:GENERAR_CON_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Guayaquil
APP_URL=https://recaudacion.cotopaxi.gob.ec

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# Base de Datos PRODUCCIÓN
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=recaudacion_prod
DB_USERNAME=recaudacion_user
DB_PASSWORD=CAMBIAR_POR_CONTRASEÑA_FUERTE_64_CARACTERES_RANDOM

# Cache & Session (usar Redis en producción)
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# Queue (usar Redis/Database en producción)
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cotopaxi.gob.ec
MAIL_PASSWORD=CAMBIAR
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@cotopaxi.gob.ec"
MAIL_FROM_NAME="${APP_NAME}"

# Pasarela de Pagos - Pago Medios
PAYMENT_GATEWAY_API_URL="https://api.abitmedia.cloud/pagomedios/v2/payment-requests"
PAYMENT_GATEWAY_API_KEY=CAMBIAR_POR_API_KEY_PRODUCCION
PAYMENT_GATEWAY_WEBHOOK_URL="https://recaudacion.cotopaxi.gob.ec/webhook/pago"

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Seguridad
BCRYPT_ROUNDS=12
